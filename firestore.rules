rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can read and write only their own data tree.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Platform-wide aggregate analytics. Non-sensitive counters maintained
    // exclusively by Cloud Functions (Admin SDK bypasses these rules). Any
    // signed-in user may read; no client may write.
    match /platform/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
