rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Each user can read/write only files under their own folder in the platform namespace.
    match /antonov3d/users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Keep old path for backward compatibility if needed, or if some functions still use it.
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
