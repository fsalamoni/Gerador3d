{
  "name": "gerador3d-functions",
  "version": "0.1.0",
  "description": "Cloud Functions proxy for 3D generation providers (BYOK).",
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "firebase-admin": "^12.1.0",
    "firebase-functions": "^5.0.1",
    "@google-cloud/firestore": "^7.8.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
