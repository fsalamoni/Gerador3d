# ─────────────────────────────────────────────────────────────────────────────
# Gerador3D — Frontend environment variables
# Copy this file to `.env.local` and fill in with your own Firebase project.
# Without these values the app runs in DEMO MODE (no real persistence/auth).
# ─────────────────────────────────────────────────────────────────────────────

# Firebase Web App config (Project settings → Your apps → SDK setup & config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — Google Analytics for Firebase (gtag) measurement id (G-XXXXXXX).
VITE_FIREBASE_MEASUREMENT_ID=

# Optional — region where the Cloud Functions are deployed (default us-central1).
VITE_FUNCTIONS_REGION=

# Optional — base URL of the deployed Cloud Functions (3D generation proxy).
# Leave empty to use the default Firebase Functions URL derived at runtime.
VITE_FUNCTIONS_BASE_URL=

# Optional — email that should be treated as the platform admin.
VITE_ADMIN_EMAIL=

# Optional — force demo mode even when Firebase config is present.
VITE_DEMO_MODE=false
